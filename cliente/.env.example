# Where Nest listens. Used by Next.js rewrites (/api/backend → NEST_ORIGIN).
# Not prefixed with NEXT_PUBLIC_ so it is not inlined into the browser bundle.
NEST_ORIGIN=http://127.0.0.1:4001

# Browser API base. Leave unset to use same-origin proxy: /api/backend (recommended).
# Set only if the client must call Nest directly (e.g. mobile web on another host):
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:3001
